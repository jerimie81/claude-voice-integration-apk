<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="accent_amber">#D97706</color>
    <color name="accent_amber_light">#F59E0B</color>
    <color name="accent_red">#EF4444</color>
    <color name="background_dark">#0F0F1A</color>
    <color name="border_dark">#2A2A40</color>
    <color name="border_light">#3A3A55</color>
    <color name="status_bar">#0A0A14</color>
    <color name="surface_dark">#1C1C2E</color>
    <color name="surface_elevated">#252540</color>
    <color name="text_muted">#555570</color>
    <color name="text_primary">#F0F0F5</color>
    <color name="text_secondary">#8890A0</color>
    <string name="app_name">Claude Voice</string>
    <style name="Theme.ClaudeVoice" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_amber</item>
        <item name="colorPrimaryVariant">@color/accent_amber_light</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_amber</item>
        <item name="colorSecondaryVariant">@color/accent_amber_light</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="Theme.ClaudeVoice.Settings" parent="Theme.ClaudeVoice">
        <item name="android:statusBarColor">@color/status_bar</item>
    </style>
</resources>