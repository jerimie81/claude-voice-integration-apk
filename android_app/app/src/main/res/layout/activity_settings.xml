<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark"
    android:fitsSystemWindows="true">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Server Settings"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_dark" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- IP field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="PC IP Address"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <EditText
            android:id="@+id/etIp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_settings_input"
            android:hint="e.g. 192.168.1.100"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="16sp"
            android:inputType="text"
            android:fontFamily="sans-serif" />

        <!-- Port field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="PC Port"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <EditText
            android:id="@+id/etPort"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_settings_input"
            android:hint="5000"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="16sp"
            android:inputType="number"
            android:fontFamily="sans-serif" />

        <!-- Bearer token field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Bearer Token"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <EditText
            android:id="@+id/etToken"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_settings_input"
            android:hint="from PC install.sh output"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="16sp"
            android:inputType="textPassword"
            android:fontFamily="sans-serif" />

        <!-- Request timeout field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="Request Timeout (seconds)"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <EditText
            android:id="@+id/etTimeout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_settings_input"
            android:hint="300"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="16sp"
            android:inputType="number"
            android:fontFamily="sans-serif" />

    </LinearLayout>

    <!-- Save button pinned to bottom -->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_save_button"
        android:text="Save"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-medium" />

</LinearLayout>
