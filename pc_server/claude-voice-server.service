[Unit]
Description=Claude Voice Integration Server
Documentation=https://github.com/redrum/claude-voice-integration
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Wait up to 30s for the WireGuard tunnel address to appear before binding.
# wg-quick@wg0 is a system service — a user unit cannot Require it directly,
# so we poll for the bind address instead. Restart=on-failure handles the
# rest if the tunnel comes up later.
ExecStartPre=/bin/sh -c 'for i in $(seq 1 30); do %h/.local/bin/python3 -c "import socket,os; s=socket.socket(); s.bind((os.environ[\"CLAUDE_VOICE_HOST\"],0)); s.close()" 2>/dev/null && exit 0; sleep 1; done; exit 1'
ExecStart=%h/.local/bin/python3 %h/.gemini/Development/claude_voice_integration/pc_server/claude_webhook_server.py
Restart=on-failure
RestartSec=5

# Override any of these with: systemctl --user edit claude-voice-server
Environment=CLAUDE_VOICE_PORT=5000
Environment=CLAUDE_VOICE_HOST=10.7.0.1
# Bearer token lives in a 0600 EnvironmentFile so it stays out of the unit.
# install.sh writes CLAUDE_VOICE_TOKEN=<random> into this file.
EnvironmentFile=%h/.config/claude-voice/server.env
# Environment=CLAUDE_VOICE_CLAUDE_BIN=/home/youruser/.local/bin/claude
# Environment=CLAUDE_VOICE_LOG=/home/youruser/.claude-voice-server.log

StandardOutput=journal
StandardError=journal
SyslogIdentifier=claude-voice-server

[Install]
WantedBy=default.target
